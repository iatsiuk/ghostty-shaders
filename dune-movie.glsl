// fetch a single texel: 4 pixels per uint32, 8 bits each
vec3 fetchTexel(int x, int y) {
    int linear = y * TEX_W + x;
    int wordIdx = linear / 4;
    int bitOff = (linear % 4) * 8;
    uint w = TEX_DATA[wordIdx];
    uint idx = (w >> uint(bitOff)) & 255u;
    return PALETTE[int(idx)];
}

vec3 fetchShipPixel(int x, int y) {
    int linear = y * SHIP_W + x;
    int wordIdx = linear / 4;
    int bitOff = (linear % 4) * 8;
    uint w = SHIP_DATA[wordIdx];
    uint idx = (w >> uint(bitOff)) & 255u;
    return SHIP_PAL[int(idx)];
}

// sample texture by (u, v) in [0, 1]; u wraps, v clamps
vec3 sampleTex(vec2 uv) {
    float fx = fract(uv.x) * float(TEX_W);
    float fy = clamp(uv.y, 0.0, 0.999) * float(TEX_H);
    return fetchTexel(int(fx), int(fy));
}

float hash21(vec2 p) {
    vec3 p3 = fract(vec3(p.xyx) * 0.1031);
    p3 += dot(p3, p3.yzx + 33.33);
    return fract((p3.x + p3.y) * p3.z);
}

// smooth value noise in 2d
float valueNoise(vec2 p) {
    vec2 i = floor(p);
    vec2 f = fract(p);
    f = f * f * (3.0 - 2.0 * f);
    float a = hash21(i);
    float b = hash21(i + vec2(1.0, 0.0));
    float c = hash21(i + vec2(0.0, 1.0));
    float d = hash21(i + vec2(1.0, 1.0));
    return mix(mix(a, b, f.x), mix(c, d, f.x), f.y);
}

// fractal brownian motion: different octave counts for different detail needs.
// each unrolls to a straight-line sequence without a loop.
float fbm5(vec2 p) {
    float v  = 0.5    * valueNoise(p);            p = p * 2.03 + vec2(17.17, 7.13);
          v += 0.25   * valueNoise(p);            p = p * 2.03 + vec2(17.17, 7.13);
          v += 0.125  * valueNoise(p);            p = p * 2.03 + vec2(17.17, 7.13);
          v += 0.0625 * valueNoise(p);            p = p * 2.03 + vec2(17.17, 7.13);
          v += 0.03125 * valueNoise(p);
    return v;
}
float fbm3(vec2 p) {
    float v  = 0.5   * valueNoise(p);             p = p * 2.03 + vec2(17.17, 7.13);
          v += 0.25  * valueNoise(p);             p = p * 2.03 + vec2(17.17, 7.13);
          v += 0.125 * valueNoise(p);
    return v;
}
float fbm2(vec2 p) {
    float v  = 0.5  * valueNoise(p);              p = p * 2.03 + vec2(17.17, 7.13);
          v += 0.25 * valueNoise(p);
    return v;
}

// elegant star: soft round core + 4 long main spikes + 4 shorter diagonal
// spikes. everything falls off smoothly via smoothstep, no hard pixel edges.
float starMask(vec2 d, float arm) {
    vec2 a = abs(d);
    // primary cross spikes (long, thin)
    float spikeH = smoothstep(arm,       0.0, a.x) * smoothstep(0.35, 0.0, a.y);
    float spikeV = smoothstep(arm,       0.0, a.y) * smoothstep(0.35, 0.0, a.x);
    // diagonal spikes (shorter, thinner)
    vec2 rd = vec2(d.x + d.y, d.x - d.y) * 0.70710678;
    vec2 ar = abs(rd);
    float diag = smoothstep(arm * 0.55, 0.0, ar.x) * smoothstep(0.22, 0.0, ar.y)
               + smoothstep(arm * 0.55, 0.0, ar.y) * smoothstep(0.22, 0.0, ar.x);
    // bright round core
    float core = smoothstep(1.2, 0.0, length(d));
    return clamp(core + (spikeH + spikeV) * 0.85 + diag * 0.45, 0.0, 1.0);
}

vec3 drawStars(vec2 fragCoord, float pxSize) {
    float cell = 9.0 * pxSize;
    vec2 id = floor(fragCoord / cell);
    vec2 local = mod(fragCoord, cell);

    float h = hash21(id);
    if (h < 0.94375) return vec3(0.0);

    vec2 cPx = floor(vec2(hash21(id + 17.0), hash21(id + 31.0)) * (cell / pxSize));
    vec2 c = (cPx + 0.5) * pxSize;
    vec2 d = (local - c) / pxSize;

    float sizeRoll = hash21(id + 51.0);
    float arm = sizeRoll > 0.9 ? 2.8 : (sizeRoll > 0.6 ? 2.0 : 1.2);
    float m = starMask(d, arm);
    if (m < 0.02) return vec3(0.0);   // skip near-zero pixels

    vec3 tint = mix(vec3(0.75, 0.85, 1.0), vec3(1.0, 1.0, 1.0), hash21(id + 71.0));
    float tw = 0.55 + 0.45 * sin(iTime * (0.3 + h * 0.5) + h * 6.28);
    float bright = (arm > 2.5) ? 1.0 : (arm > 1.5 ? 0.75 : 0.45);
    return tint * bright * tw * m;   // m provides the smooth gradient
}

// --- text detection thresholds --------------------------------------------
// we can't ask ghostty "is this pixel text or terminal-background?", so we
// approximate by luminance: anything darker than TEXT_LUM_LOW is treated as
// pure background (our shader shows through), anything brighter than
// TEXT_LUM_HIGH is treated as pure text (shown on top), values in between
// smoothly blend. if your terminal bg isn't #000000 (e.g. #0a0a0a), raise
// TEXT_LUM_LOW above its luminance so the bg doesn't dim our image.
// ---------------------------------------------------------------------------
const float TEXT_LUM_LOW  = 0.12;
const float TEXT_LUM_HIGH = 0.25;

// --- background brightness -------------------------------------------------
// multiplier applied to everything we render (planet, ring, stars, ship)
// *before* the terminal text is composited on top. lower -> darker backdrop,
// easier-to-read text; higher -> brighter image, text starts to tunnel into it.
//
// valid range: >= 0.0 (no upper limit, but >1.0 pushes pixels past full bright
// and Metal will clamp in the swapchain).
//
// useful values:
//   0.00  -> pure black behind the text (shader effectively off visually)
//   0.30  -> very dim, almost subliminal backdrop
//   0.45  -> balanced, text very readable (our earlier default)
//   0.70  -> image prominent but still legible
//   0.80  -> current default, colors close to source
//   1.00  -> full source brightness (may wash out dark syntax colors)
//   >1.0  -> overbright / bloom-like, only useful if you have a very dark
//           terminal theme and want the planet to pop
// ---------------------------------------------------------------------------
const float BG_BRIGHTNESS = 0.6;

// precomputed ring/light constants (compile-time; no sin/cos/normalize at runtime)
const float SIN_A           = 0.31456656;
const float COT_A           = 3.01759798;
const float INV_SIN_A       = 3.17897744;
const float RING_INNER_SQ   = 1.21000000;
const float RING_OUTER_SQ   = 5.76000000;
const float RING_INV_SPREAD_SQ = 2.36686391;
const vec3  LIGHT_DIR       = vec3(-0.94881472, 0.09987523, 0.29962570);
const float PHI_INV         = 0.6180339887;
const float INV_2PI         = 0.15915494309;
const float INV_PI          = 0.31830988618;

void mainImage(out vec4 fragColor, in vec2 fragCoord) {
    // -------- per-frame invariants (hoisted so they're computed once
    // per warp, not per pixel; the Metal compiler can scalarize these) --
    float pr     = min(iResolution.x * PLANET_W_FRAC,
                       iResolution.y * PLANET_H_FRAC);
    float invPr  = 1.0 / pr;
    float pxSize = max(2.0, floor(iResolution.y * 0.0045));
    vec2  center = iResolution.xy * PHI_INV;

    float spinAngle = iTime * SPIN_SPEED;
    float spinCos = cos(spinAngle);
    float spinSin = sin(spinAngle);
    float flowPhase = iTime * 0.0109375;
    float flowFine  = iTime * 0.0625;

    float shipPx = max(2.0, floor(iResolution.x * 0.11
                                  / float(SHIP_W)));
    float dispW  = float(SHIP_W) * shipPx;
    float dispH  = float(SHIP_H) * shipPx;
    float invShipPx = 1.0 / shipPx;
    float bob    = sin(iTime * 0.3) * shipPx * 3.0;
    vec2  shipC  = vec2(iResolution.x * 0.5,
                        iResolution.y * 0.78 + bob);
    vec2  shipMin = shipC - vec2(dispW, dispH) * 0.5;

    // -------- per-pixel geometry relative to the planet --------
    vec2 p = fragCoord - center;
    vec2 n = vec2(p.x, -p.y) * invPr;
    float r2 = dot(n, n);

    vec3 bg = vec3(0.0);

    if (r2 < 1.0) {
        // -------- inside planet disc: 3D sphere rendering --------
        float z = sqrt(1.0 - r2);
        vec3 normal = vec3(n.x, n.y, z);

        // rotate around Y axis; trig hoisted above
        vec3 sp = vec3(normal.x * spinCos + normal.z * spinSin,
                       normal.y,
                       -normal.x * spinSin + normal.z * spinCos);

        // equirectangular UV from sphere point (precomputed 1/pi)
        float lon = atan(sp.x, sp.z);
        float lat = asin(clamp(sp.y, -1.0, 1.0));
        vec3 base = sampleTex(vec2(lon * INV_2PI + 0.5,
                                   0.5 - lat * INV_PI));

        // Lambert diffuse with precomputed normalized light dir
        float diff = max(0.0, dot(normal, LIGHT_DIR));
        float shade = 0.03 + 1.55 * diff;

        // rim light only on the illuminated (left) edge
        float oneMinusZ = 1.0 - z;
        float rim = oneMinusZ * oneMinusZ * oneMinusZ
                  * max(0.0, -n.x) * 0.8;

        bg = base * shade + vec3(0.25, 0.45, 0.9) * rim;
    } else {
        // -------- outside planet disc: stars + halo --------
        bg = drawStars(fragCoord, pxSize);

        float d = sqrt(r2) - 1.0;
        float halo = exp(-d * 14.0) * 0.55;
        bg += vec3(0.12, 0.32, 0.85) * halo;
    }

    // -------- equatorial gas streams (early-out via squared distance) --------
    // bbox: if n.x^2 or (n.y*invSinA)^2 exceed outer radius^2, skip entirely
    float ryLocal = n.y * INV_SIN_A;
    float rRingSq = n.x * n.x + ryLocal * ryLocal;
    if (rRingSq >= RING_INNER_SQ && rRingSq <= RING_OUTER_SQ) {
        float zRing = n.y * COT_A;
        bool ringVisible = true;
        if (r2 < 1.0) {
            if (zRing < sqrt(1.0 - r2)) ringVisible = false;
        }
        if (ringVisible) {
            float rRing = sqrt(rRingSq);
            float phi = atan(n.x, ryLocal);
            float flow = phi + flowPhase;
            float dr = (rRing - 1.6);
            vec2 pCoarse = vec2(flow * 1.2, dr * 1.8);
            vec2 pFine   = vec2(flow * 4.5 - flowFine, dr * 5.0);
            // coarse structure: 3 octaves suffice. fine detail: 4 octaves.
            float dens = fbm3(pCoarse) * 0.65 + fbm3(pFine) * 0.5;
            dens = max(0.0, dens - 0.35) * 1.6;
            dens = pow(dens, 1.35);
            // gaussian fall-off, reusing precomputed 1/spread^2
            float radial = exp(-dr * dr * RING_INV_SPREAD_SQ * 2.2);
            float shadow = 1.0;
            if (zRing < 0.0) {
                float inPlanetShadow = smoothstep(1.05, 0.80,
                    length(vec2(n.x, ryLocal * SIN_A)));
                shadow = mix(1.0, 0.30, inPlanetShadow);
            }
            bg += vec3(0.22, 0.55, 1.0) * dens * radial * shadow * 1.15;
        }
    }

    // -------- ship sprite (early-out via bbox check before any work) --------
    vec2 rel = fragCoord - shipMin;
    if (rel.x >= 0.0 && rel.x < dispW && rel.y >= 0.0 && rel.y < dispH) {
        int sx = clamp(int(floor(rel.x * invShipPx)), 0, SHIP_W - 1);
        int sy = clamp(int(floor(rel.y * invShipPx)), 0, SHIP_H - 1);
        vec3 sc = fetchShipPixel(sx, sy);

        // blue-dominant pixels are the exhaust flame; animate them only.
        if ((sc.b > sc.r + 0.15) && (sc.b > 0.30)) {
            // cheaper noise for subtle animation (2-3 octaves)
            float wob = fbm2(vec2(float(sy) * 0.4 + iTime * 2.5,
                                  iTime * 1.2)) - 0.5;
            int ssx = clamp(sx + int(wob * 4.0), 0, SHIP_W - 1);
            vec3 s2 = fetchShipPixel(ssx, sy);
            if ((s2.b > s2.r + 0.10) && (s2.b > 0.25)) sc = s2;

            float flick = 0.65 + 0.80 * fbm3(vec2(float(sx) * 0.18
                                                  + iTime * 5.5,
                                                  float(sy) * 0.25));
            sc *= flick;

            float flash = max(0.0,
                fbm2(vec2(float(sx) * 0.07 - iTime * 7.0,
                          float(sy) * 0.3)) - 0.55) * 2.2;
            sc += vec3(0.30, 0.55, 0.95) * flash;
        }

        if (max(sc.r, max(sc.g, sc.b)) > 0.08) bg = sc;
    }

    // composite with terminal: dim the image, keep text legible.
    vec2 uv = fragCoord / iResolution.xy;
    vec3 term = texture(iChannel0, uv).rgb;
    float termLum = max(term.r, max(term.g, term.b));
    float textMask = smoothstep(TEXT_LUM_LOW, TEXT_LUM_HIGH, termLum);
    fragColor = vec4(mix(bg * BG_BRIGHTNESS, term, textMask), 1.0);
}
